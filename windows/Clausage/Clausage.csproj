<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <ApplicationIcon>Resources\clausage.ico</ApplicationIcon>
    <AssemblyName>Clausage</AssemblyName>
    <RootNamespace>Clausage</RootNamespace>
    <Version>0.1.0</Version>
  </PropertyGroup>

  <ItemGroup>
    <EmbeddedResource Include="..\..\Clausage\Resources\pricing.json" Link="Resources\pricing.json" />
    <InternalsVisibleTo Include="Clausage.Tests" />
  </ItemGroup>

</Project>
